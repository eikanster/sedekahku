{
  "id": "/",
  "name": "QRSedekah",
  "short_name": "QRSedekah",
  "description": "Daily infaq and sedekah to Malaysian masjid and surau using DuitNow QR",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "orientation": "portrait",
  "background_color": "#062B44",
  "theme_color": "#093C5D",
  "lang": "ms",
  "dir": "ltr",
  "categories": ["education", "lifestyle", "social", "utilities"],
  "prefer_related_applications": false,
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "handle_links": "preferred",
  "edge_side_panel": {
    "preferred_width": 400
  },
  "icons": [
    {
      "src": "icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/maskable_icon.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "screenshots/screen-home.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Skrin Utama - senarai masjid dan kempen"
    },
    {
      "src": "screenshots/screen-qr.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "QR DuitNow untuk berinfaq"
    },
    {
      "src": "screenshots/screen-scan.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Imbas dan simpan QR masjid tempatan"
    }
  ],
  "shortcuts": [
    {
      "name": "Imbas QR",
      "short_name": "Imbas",
      "description": "Imbas QR DuitNow masjid baharu",
      "url": "/?action=scan",
      "icons": [{ "src": "icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Kegemaran Saya",
      "short_name": "Kegemaran",
      "description": "Lihat senarai masjid kegemaran",
      "url": "/?action=fav",
      "icons": [{ "src": "icons/icon-192.png", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "/",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+qrsedekah",
      "url": "/?qr=%s"
    }
  ]
}
